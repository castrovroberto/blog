<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Roberto Castro</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <div class="site-wrapper">
      <h1><a href="/">Roberto Castro</a></h1>
      <nav>
        <a href="/">Home</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="site-wrapper">
      <article>
        <div class="post-header">
          <h1>{{ title }}</h1>
          <p class="post-meta">{{ date | readableDate("MMMM d, yyyy") }}</p>
        </div>
        <div class="post-content">
          {{ content | safe }}
        </div>
        <div class="post-footer">
          <a href="/">← Back to home</a>
        </div>
      </article>
    </div>
  </main>

  <footer>
    <div class="site-wrapper">
      <p>&copy; 2025 Roberto Castro</p>
    </div>
  </footer>
</body>
</html>
